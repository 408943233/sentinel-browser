{
  "name": "sentinel-browser",
  "version": "2.0.0",
  "description": "Industrial-grade web application data collector for VLA model training",
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron . --no-sandbox --disable-gpu --disable-software-rasterizer --disable-features=IsolateOrigins,site-per-process",
    "dev": "NODE_ENV=development electron . --no-sandbox --disable-gpu --disable-software-rasterizer --disable-features=IsolateOrigins,site-per-process",
    "build": "electron-builder",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win",
    "build:all": "electron-builder --mac --win",
    "test": "jest",
    "lint": "eslint src/",
    "postinstall": "electron-builder install-app-deps"
  },
  "keywords": [
    "electron",
    "browser",
    "data-collection",
    "vla",
    "automation"
  ],
  "author": "Sentinel Team",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "eslint": "^8.56.0",
    "jest": "^29.7.0"
  },
  "dependencies": {
    "archiver": "^6.0.1",
    "electron-log": "^5.0.1"
  },
  "build": {
    "appId": "com.sentinel.browser",
    "productName": "Sentinel Browser",
    "copyright": "Copyright © 2024 Sentinel Team",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "src/**/*",
      "assets/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "bin/",
        "to": "bin/",
        "filter": [
          "**/*"
        ]
      }
    ],
    "asar": true,
    "asarUnpack": [
      "bin/**/*"
    ],
    "mac": {
      "category": "public.app-category.utilities",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "assets/icon.icns"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": true,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Sentinel Browser",
      "artifactName": "${productName}-Setup-${version}.${ext}",
      "deleteAppDataOnUninstall": false,
      "warningsAsErrors": false,
      "runAfterFinish": true,
      "menuCategory": false
    },
    "portable": {
      "artifactName": "${productName}-Portable-${version}.${ext}"
    },
    "publish": null
  }
}
